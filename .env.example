# ─── Auth ────────────────────────────────────────────────────────────────────
# Default secret lets the app start immediately — change before going to production.
# Generate a strong secret: https://generate-secret.vercel.app/32
# ⚠ Changing this invalidates all existing sessions — users will need to log in again.
AUTH_SECRET=fractera-change-me

# Optional: architect token for direct admin access via /api/auth/architect?token=
# ARCHITECT_TOKEN=your-token-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_TITLE=Fractera Light
NEXT_PUBLIC_APP_DESCRIPTION=AI-powered development workspace
NEXT_PUBLIC_APP_VERSION=1.2.0

# Language code for <html lang="..."> — display only, no i18n system
# Affects joke culture in agent responses
NEXT_PUBLIC_LANG=en

# Theme: light | dark | system
NEXT_PUBLIC_DEFAULT_THEME=light

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite path. Default: data/fractera-light.db
# DATABASE_URL=file:./data/fractera-light.db

# ─── Links (footer) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/fractera-light
NEXT_PUBLIC_PRO_URL=https://github.com/your-org/fractera
NEXT_PUBLIC_SKILLS_URL=https://fractera.ai

# ─── Auto-update ─────────────────────────────────────────────────────────────
# Upstream repo for the Update button in coding workspace footer
UPSTREAM_REPO_URL=https://github.com/Fractera/fractera-light.git

# ─── Media Service ───────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDIA_URL=http://localhost:3300

# ─── Code Platforms Bridge ───────────────────────────────────────────────────
# All bridges run from a single process: bridges/claude-code/server.js
# Start: cd bridges/claude-code && node server.js
NEXT_PUBLIC_BRIDGE_URL=ws://localhost:3200
NEXT_PUBLIC_PTY_URL=ws://localhost:3201
NEXT_PUBLIC_CODEX_URL=ws://localhost:3202
NEXT_PUBLIC_GEMINI_URL=ws://localhost:3203
NEXT_PUBLIC_QWEN_URL=ws://localhost:3204
NEXT_PUBLIC_KIMI_URL=ws://localhost:3205
NEXT_PUBLIC_OPENCODE_URL=ws://localhost:3206

# ─── OpenRouter (Open Code platform) ─────────────────────────────────────────
# Get free key: https://openrouter.ai/workspaces/default/keys
# Or set via the Data button in the coding workspace UI
# OPENROUTER_API_KEY=sk-or-...
