# Copy this file to .env.local and fill in the values.
# cp .env.local.example .env.local

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: https://generate-secret.vercel.app/32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Optional: direct admin access via /api/auth/architect?token=
# ARCHITECT_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_TITLE=Fractera Light
NEXT_PUBLIC_APP_DESCRIPTION=AI-powered development workspace
NEXT_PUBLIC_APP_VERSION=1.2.2
NEXT_PUBLIC_LANG=en
NEXT_PUBLIC_DEFAULT_THEME=light

# ─── Links (footer) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_PRO_URL=
NEXT_PUBLIC_SKILLS_URL=

# ─── Auto-update ─────────────────────────────────────────────────────────────
UPSTREAM_REPO_URL=https://github.com/Fractera/fractera-light.git

# ─── Media Service ───────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDIA_URL=http://localhost:3300

# ─── Code Platforms Bridge ───────────────────────────────────────────────────
NEXT_PUBLIC_BRIDGE_URL=ws://localhost:3200
NEXT_PUBLIC_PTY_URL=ws://localhost:3201
NEXT_PUBLIC_CODEX_URL=ws://localhost:3202
NEXT_PUBLIC_GEMINI_URL=ws://localhost:3203
NEXT_PUBLIC_QWEN_URL=ws://localhost:3204
NEXT_PUBLIC_KIMI_URL=ws://localhost:3205
NEXT_PUBLIC_OPENCODE_URL=ws://localhost:3206

# ─── OpenCode (Open Code platform) ───────────────────────────────────────────
# Required to use Open Code. Get a free key: https://openrouter.ai/keys
# After adding, restart the bridge: pm2 restart fractera-bridge
OPENROUTER_API_KEY=

# ─── Gemini CLI ───────────────────────────────────────────────────────────────
# Optional: non-interactive auth for Gemini CLI (subscription login preferred)
# GEMINI_API_KEY=

# ─── Qwen Code ────────────────────────────────────────────────────────────────
# Optional: non-interactive auth for Qwen Code (subscription login preferred)
# DASHSCOPE_API_KEY=
