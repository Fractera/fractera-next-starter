# Copy this file to .env.local and fill in the values.
# cp .env.local.example .env.local

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: https://generate-secret.vercel.app/32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Optional: direct admin access via /api/auth/architect?token=
# ARCHITECT_TOKEN=

# ─── Shell iframe URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_URL=http://auth.partner.fractera.local:3001
NEXT_PUBLIC_ADMIN_URL=http://admin.partner.fractera.local:3002

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_TITLE=Fractera Light
NEXT_PUBLIC_APP_DESCRIPTION=AI-powered development workspace
NEXT_PUBLIC_APP_VERSION=1.2.2
NEXT_PUBLIC_LANG=en
NEXT_PUBLIC_DEFAULT_THEME=light

# ─── Languages (multilingual content routing) ────────────────────────────────
# Comma-separated list of language codes the site serves. Two or more → the
# language switcher button appears and content lives under /<lang>/… . Leave a
# SINGLE language → the button disappears and pages are served from the root with
# no prefix (single-language mode). The default ships bilingual (English + Spanish)
# so the switcher is visible out of the box.
# IMPORTANT: these are NEXT_PUBLIC_* — baked into the build. Changing them needs a
# rebuild to take effect. Service pages (/architecture, /ai-core, …) always stay
# at the root regardless of this setting.
# Full immutable CATALOG of all possible languages (82, ISO 639-1). A source-of-
# truth reference list, NOT the active set. The active languages live in
# NEXT_PUBLIC_SUPPORTED_LANGUAGES below (a subset drawn from this catalog).
# Mirrors the keys of config/translations/language-metadata.ts. Not yet wired
# into code — kept here as the canonical raw enumeration.
NEXT_PUBLIC_ALL_LANGUAGES=en,fr,es,pt,de,it,nl,sv,no,da,fi,is,el,pl,cs,sk,hu,ro,hr,sl,et,lv,lt,mt,ca,gl,cy,ga,eu,ru,uk,be,bg,sr,bs,mk,sq,kk,uz,ky,tg,tk,az,hy,ka,mn,ar,tr,he,fa,ku,af,sw,ha,yo,ig,am,zu,xh,rw,so,zh,ja,ko,hi,ur,bn,te,mr,kn,gu,ml,ta,ne,vi,th,id,ms,tl,my,km,lo
NEXT_PUBLIC_SUPPORTED_LANGUAGES=en,es
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ─── Links (footer) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_PRO_URL=
NEXT_PUBLIC_SKILLS_URL=

# ─── Auto-update ─────────────────────────────────────────────────────────────
UPSTREAM_REPO_URL=https://github.com/Fractera/fractera-light.git

# ─── Media Service ───────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDIA_URL=http://localhost:3300

# ─── Remote Data DB (для локальной разработки) ───────────────────────────────
# Раскомментировать для работы с БД на сервере вместо локального SQLite
# REMOTE_DATA_URL=https://data.SUBDOMAIN.fractera.ai
# DATA_API_KEY=<тот же секрет что DATA_SECRET на сервере>

# ─── Code Platforms Bridge ───────────────────────────────────────────────────
NEXT_PUBLIC_BRIDGE_URL=ws://localhost:3200
NEXT_PUBLIC_PTY_URL=ws://localhost:3201
NEXT_PUBLIC_CODEX_URL=ws://localhost:3202
NEXT_PUBLIC_GEMINI_URL=ws://localhost:3203
NEXT_PUBLIC_QWEN_URL=ws://localhost:3204
NEXT_PUBLIC_KIMI_URL=ws://localhost:3205
NEXT_PUBLIC_OPENCODE_URL=ws://localhost:3206

# ─── OpenCode (Open Code platform) ───────────────────────────────────────────
# Required to use Open Code. Get a free key: https://openrouter.ai/keys
# After adding, restart the bridge: pm2 restart fractera-bridge
OPENROUTER_API_KEY=

# ─── Gemini CLI ───────────────────────────────────────────────────────────────
# Optional: non-interactive auth for Gemini CLI (subscription login preferred)
# GEMINI_API_KEY=

# ─── Qwen Code ────────────────────────────────────────────────────────────────
# Optional: non-interactive auth for Qwen Code (subscription login preferred)
# DASHSCOPE_API_KEY=
