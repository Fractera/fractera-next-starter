{
  "mcpServers": {
    "app-settings-bridge": {
      "httpUrl": "http://localhost:3218",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    },
    "content-crud-bridge": {
      "httpUrl": "http://localhost:3226",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    },
    "content-orchestrator-bridge": {
      "httpUrl": "http://localhost:3227",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    }
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace|edit_file|overwrite_file",
        "hooks": [
          {
            "name": "brain-ingest",
            "type": "command",
            "command": "bash -c 'AGENT_IDENTITY=gemini python3 /opt/fractera/app/.agent-hooks/brain-ingest.py'",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
