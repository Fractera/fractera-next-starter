{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace|edit_file|overwrite_file",
        "hooks": [
          {
            "name": "brain-ingest",
            "type": "command",
            "command": "bash -c 'AGENT_IDENTITY=gemini python3 /opt/fractera/app/.agent-hooks/brain-ingest.py'",
            "timeout": 15000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "description": "DEMO (fake) — drive a real browser for testing and scraping."
    }
  }
}
