# dependencies
node_modules/

# next.js
.next/
out/

# env
.env
.env.local
.env.*.local

# database (root legacy + data/ folder)
database.sqlite
database.sqlite-shm
database.sqlite-wal
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal

# user files — stay on server, not in git
storage/*
!storage/.gitkeep
data/*
!data/.gitkeep

# knowledge base documents — real user files, never synced to GitHub.
# Leading slash anchors this to the app root so it does NOT match the source dirs
# lib/crud-docs/ or components/crud-docs/ under case-insensitive git (Windows).
# Ignore the directory CONTENTS (same pattern as storage/ and data/ above) but ship
# the read-only seed knowledge docs, so a fresh clone / agent starts with a base corpus.
/CRUD-DOCS/*
!/CRUD-DOCS/ai-workspace-architecture.md
!/CRUD-DOCS/fractera-project-overview.md
!/CRUD-DOCS/workspace-standards
!/CRUD-DOCS/workspace-standards/*

# build
dist/
tsconfig.tsbuildinfo

# os
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
