{
  "mcpServers": {
    "app-settings-bridge": {
      "httpUrl": "http://localhost:3218",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    },
    "content-crud-bridge": {
      "httpUrl": "http://localhost:3226",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    },
    "content-orchestrator-bridge": {
      "httpUrl": "http://localhost:3227",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    },
    "language-expansion-bridge": {
      "httpUrl": "http://localhost:3228",
      "headers": {
        "Authorization": "Bearer ${HERMES_MCP_SECRET}"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'AGENT_IDENTITY=qwen python3 /opt/fractera/app/.agent-hooks/brain-ingest.py'"
          }
        ]
      }
    ]
  }
}
